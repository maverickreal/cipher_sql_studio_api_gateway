{
  "name": "cipher_sql_studio",
  "version": "1.0.0",
  "description": "The backend for an online SQL compiler website.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:create": "npx ts-migrate-mongoose create",
    "migrate:up": "npx ts-migrate-mongoose up",
    "migrate:down": "npx ts-migrate-mongoose down",
    "migrate:list": "npx ts-migrate-mongoose list",
    "migrate:prune": "npx ts-migrate-mongoose prune",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "maverick",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bullmq": "^5.70.4",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.2.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-roll": "^4.0.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "ts-migrate-mongoose": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
